{
  "name": "elevarus-os",
  "version": "0.1.0",
  "description": "ElevarusOS — internal agent orchestration system, starting with the Blog Research and Draft Bot",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && copyfiles -u 1 \"src/**/*.md\" \"src/**/*.svg\" dist/",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "ts-node-dev --respawn --exit-child src/index.ts",
    "typecheck": "tsc --noEmit",
    "setup": "bash setup.sh",
    "setup:dashboard": "cd dashboard && pnpm install --frozen-lockfile 2>/dev/null || npm install --legacy-peer-deps",
    "dashboard:dev": "cd dashboard && pnpm dev",
    "dashboard:build": "cd dashboard && pnpm build",
    "start:all": "concurrently --kill-others-on-fail --names \"ElevarusOS,Dashboard\" --prefix-colors \"cyan,magenta\" \"npm run dev:watch\" \"npm run dashboard:dev\"",
    "start:full": "concurrently --kill-others-on-fail --names \"ElevarusOS,Dashboard,Ngrok\" --prefix-colors \"cyan,magenta,yellow\" \"npm run dev:watch\" \"npm run dashboard:dev\" \"npm run tunnel\"",
    "tunnel": "ngrok http 3001 --log=stdout --log-format=logfmt",
    "once": "ts-node src/index.ts --once",
    "once:blog": "ts-node src/index.ts --once --bot elevarus-blog",
    "once:report": "ts-node src/index.ts --once --bot u65-reporting",
    "backfill:lp": "ts-node scripts/backfill-leadsprosper.ts",
    "backfill:ringba": "ts-node scripts/backfill-ringba.ts",
    "sync:clickup-catalog": "ts-node scripts/sync-clickup-catalog.ts",
    "sync:google-ads": "ts-node src/integrations/google-ads/sync-worker.ts",
    "agent-builder:digest": "ts-node src/core/agent-builder/digest-worker.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.103.3",
    "@types/express": "^5.0.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "node-cron": "^4.2.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "copyfiles": "^2.4.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
