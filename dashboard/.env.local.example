# ─── ElevarusOS Dashboard — Environment Variables ────────────────────────────
# Copy to .env.local (gitignored) and fill in your values.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in Supabase: Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-side only, never exposed to the browser
# Used for admin writes that bypass RLS
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── ElevarusOS API ────────────────────────────────────────────────────────────
# Base URL of the ElevarusOS API server (src/api/server.ts)

NEXT_PUBLIC_ELEVARUS_API_URL=http://localhost:3001

# API secret — server-side only (injected in Route Handlers for approve/reject)
# Must match API_SECRET in ElevarusOS .env
ELEVARUS_API_SECRET=your-api-secret-here
