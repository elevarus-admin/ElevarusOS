# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Mission Control Dashboard ───────────────────────────────────────────────
# Start the dashboard: npm run dashboard:dev  (runs on port 3000)
# The API_KEY here must match the API_KEY value you set in dashboard/.env
MISSION_CONTROL_URL=http://localhost:3000
MISSION_CONTROL_API_KEY=change-me-to-match-dashboard-api-key

# ─── ClickUp ─────────────────────────────────────────────────────────────────
# Personal API token from https://app.clickup.com/settings/apps
CLICKUP_API_TOKEN=pk_...
# The numeric ID of the ClickUp list to poll for blog content requests
CLICKUP_LIST_ID=

# ─── Microsoft Graph / Office 365 ────────────────────────────────────────────
# Azure App Registration credentials (application-level permissions)
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Shared mailbox UPN or address used for intake reads and approval sends
MS_INTAKE_MAILBOX=content-requests@yourdomain.com
MS_NOTIFY_FROM=no-reply@yourdomain.com

# ─── Slack ───────────────────────────────────────────────────────────────────
# Bot OAuth token (xoxb-...)
SLACK_BOT_TOKEN=xoxb-...
# Channel ID (not name) for workflow notifications
SLACK_NOTIFY_CHANNEL=C0123456789

# ─── Orchestrator ────────────────────────────────────────────────────────────
# How often (ms) the orchestrator polls for new intake jobs when running as a daemon
POLL_INTERVAL_MS=60000
# Maximum number of retry attempts per stage before marking the job failed
MAX_STAGE_RETRIES=2
# Log level: debug | info | warn | error
LOG_LEVEL=info
# Where to persist job records: memory | file
JOB_STORE=file
# Path used when JOB_STORE=file
JOB_STORE_PATH=./data/jobs

# ─── API server ───────────────────────────────────────────────────────────────
API_PORT=3001
# Optional: require x-api-key header on all /api/* requests
# API_SECRET=
